# Coffer configuration — copy to `.env` and edit.
#   cp .env.example .env
# `.env` is git-ignored and must never be committed (it can hold secrets).
# Anything here can also be set directly in docker-compose.yml.

# --- Image -------------------------------------------------------------------
# Which published image tag to run (used by docker-compose.yml).
COFFER_IMAGE_TAG=latest

# --- Runtime -----------------------------------------------------------------
# Host port to expose the web UI on (container always listens on 5000).
COFFER_PORT=5000

# Path to the SQLite database INSIDE the container. The data/ directory is
# bind-mounted, so the database persists on the host. Leave as-is unless you
# know why you are changing it.
DB_PATH=/app/data/coffer.db

# Timezone for dates/timestamps in the container.
TZ=Europe/London

# --- Future / optional -------------------------------------------------------
# Coffer currently ships with NO authentication (see SETUP.md → Security).
# Do not expose it to the public internet without putting auth in front of it.
# When app-level auth lands, its secret/credentials will live here — which is
# exactly why `.env` is git-ignored.
# COFFER_SECRET_KEY=
